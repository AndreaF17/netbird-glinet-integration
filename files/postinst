#!/bin/sh
# Enable and start the service on a live system only. When the package is
# installed into an image build root, IPKG_INSTROOT is set and there is no
# running procd to talk to.
[ -n "${IPKG_INSTROOT}" ] && exit 0

# Drop binaries extracted to RAM by a previous version (compressed-binary
# layout); the wrapper re-extracts the new one on first use. Skip on upgrade
# (PKG_UPGRADE=1): the payload did not change and the daemon was left running,
# so this would only force a pointless ~37 MB re-extract.
[ "${PKG_UPGRADE:-0}" = "1" ] || rm -rf /tmp/netbird-runtime

# netbird client (downloaded directly from the official netbird releases; this
# package ships no binary). The updater only transfers a binary when needed:
#   * Fresh install (no netbird.gz yet)  -> download it now.
#   * Panel upgrade (netbird.gz present) -> the updater compares the installed
#     netbird version against upstream and downloads ONLY if a newer one
#     exists; if it is already current it skips the download, so a 1.0 -> 1.1
#     panel upgrade just refreshes the panel and leaves netbird untouched.
# Best-effort and non-fatal. On a fresh install with no internet the package
# still installs and the panel's "NetBird update" card fetches netbird later;
# on a panel upgrade a failed check is ignored because the existing client
# stays in place.
UPDATER=/usr/libexec/netbird/netbird-self-update.sh
BIN_GZ=/usr/libexec/netbird/netbird.gz
if [ -x "$UPDATER" ] || [ -f "$UPDATER" ]; then
    if [ -f "$BIN_GZ" ]; then
        if [ "${PKG_UPGRADE:-0}" = "1" ]; then
            # Panel upgrade with the client already on flash: do NOT piggy-back
            # a netbird binary update -- it restarts the daemon (dropping the
            # tunnel this very upgrade may be riding at a remote site). The
            # panel's update card drives binary updates explicitly instead.
            echo "netbird: client present; skipping binary update during panel upgrade."
        else
            echo "netbird: client already installed; updating only if a newer version exists..."
            sh "$UPDATER" run >/dev/null 2>&1 || true
        fi
    else
        echo "netbird: downloading the official client from upstream..."
        sh "$UPDATER" run >/dev/null 2>&1 || \
            echo "netbird: download failed; use the panel's NetBird update card once online."
    fi
fi

/etc/init.d/netbird enable
# Start once the binary is present (a first install with no internet leaves
# netbird.gz absent; the panel can fetch it later).
[ -f "$BIN_GZ" ] && /etc/init.d/netbird start

# GL.iNet admin panel UI (native OUI page, Applications → NetBird).
# The shipped /usr/share/oui/menu.d/netbird.json carries default parent_*
# fields; patch them from an existing Applications entry on this firmware
# so the item lands in the right sidebar group regardless of GL version.
MENU=/usr/share/oui/menu.d/netbird.json
MENU_DIR=/usr/share/oui/menu.d
if [ -d "$MENU_DIR" ] && [ -f "$MENU" ]; then
    ref=""
    # Strategy 1: a sibling whose FILE NAME identifies a known
    # Applications-group app (view names inside vary across firmware:
    # e.g. Tailscale's view is "tailscaleview", not "tailscale").
    for name in tailscale zerotier adguardhome ddns plugins plug-ins \
                network_storage nas esim; do
        for f in "$MENU_DIR/$name.json" "$MENU_DIR/gl-$name.json"; do
            if [ -f "$f" ] && [ "$f" != "$MENU" ]; then ref="$f"; break 2; fi
        done
    done
    # Strategy 2: any entry whose parent looks like the Applications group.
    if [ -z "$ref" ]; then
        ref="$(grep -li '"parent": *"app' "$MENU_DIR"/*.json 2>/dev/null \
               | grep -v "/netbird.json$" | head -n1)"
    fi
    # Strategy 3: known Applications view names (incl. the *view variants).
    if [ -z "$ref" ]; then
        for view in tailscaleview tailscale zerotierview zerotier \
                    adguardhome ddns; do
            ref="$(grep -l "\"view\": *\"$view\"" "$MENU_DIR"/*.json 2>/dev/null \
                   | grep -v "/netbird.json$" | head -n1)"
            [ -n "$ref" ] && break
        done
    fi
    if [ -n "$ref" ] && [ "$ref" != "$MENU" ]; then
        parent="$(sed -n 's/.*"parent": *"\([^"]*\)".*/\1/p' "$ref" | head -n1)"
        picon="$(sed -n 's/.*"parent_icon": *"\([^"]*\)".*/\1/p' "$ref" | head -n1)"
        pindex="$(sed -n 's/.*"parent_index": *\([0-9][0-9]*\).*/\1/p' "$ref" | head -n1)"
        [ -n "$parent" ] && sed -i "s/\"parent\": *\"[^\"]*\"/\"parent\": \"$parent\"/" "$MENU"
        [ -n "$picon" ]  && sed -i "s/\"parent_icon\": *\"[^\"]*\"/\"parent_icon\": \"$picon\"/" "$MENU"
        [ -n "$pindex" ] && sed -i "s/\"parent_index\": *[0-9][0-9]*/\"parent_index\": $pindex/" "$MENU"
    fi
fi

# Hard restart of the GL web stack so OpenResty workers pick up the new RPC
# module and menu entry (reload does not reliably clear per-worker caches).
if [ -x /etc/init.d/nginx ]; then
    # shellcheck disable=SC2046
    kill -9 $(pgrep nginx) 2>/dev/null
    /etc/init.d/nginx start 2>/dev/null || true
fi

exit 0
