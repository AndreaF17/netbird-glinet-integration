#!/bin/sh
# After package files are removed: hard-restart the GL web stack so OpenResty
# workers drop the (now deleted) NetBird RPC module and menu entry, and clean
# up NetBird's transient /tmp state. Live systems only — and only where the
# GL web stack exists.
[ -n "${IPKG_INSTROOT}" ] && exit 0

# Upgrade (opkg exports PKG_UPGRADE=1; opkg passes no "upgrade" argument, the
# case below only covers dpkg-style callers): leave everything in place. The
# daemon keeps running (prerm skipped the stop), the payload stays on flash,
# an in-flight panel-update's own lock/log must survive the install it is
# driving, and the new postinst does the nginx restart once its files are in.
[ "${PKG_UPGRADE:-0}" = "1" ] && exit 0

# Drop NetBird's /tmp state: the binary extracted to RAM (compressed layout),
# the connect/update logs and locks, and the self-update cache + scratch dir.
rm -rf /tmp/netbird-runtime /tmp/netbird-prev \
       /tmp/netbird-up.log /tmp/netbird-up.lock \
       /tmp/netbird-update.log /tmp/netbird-update.lock \
       /tmp/netbird-update-check.json /tmp/netbird-update \
       /tmp/netbird-panel-update /tmp/netbird-panel-update.log \
       /tmp/netbird-panel-update.lock /tmp/netbird-panel-update.run.sh

# Reclaim the runtime-downloaded netbird payload. netbird.gz (~13 MB on the
# ~24 MB overlay) and netbird.version are written by the self-updater, so opkg
# does NOT track them and would otherwise orphan them on the flash forever.
# Skip on upgrade so the panel-upgrade fast path keeps the existing binary;
# if opkg passes no argument on upgrade we re-download in postinst, which is
# only a bandwidth cost, never data loss (config.json in /etc/netbird persists).
case "${1:-remove}" in
    upgrade) : ;;
    *)
        rm -f /usr/libexec/netbird/netbird.gz \
              /usr/libexec/netbird/netbird.version
        rmdir /usr/libexec/netbird 2>/dev/null || true
        ;;
esac

# Hard restart, not reload: OpenResty workers cache the (now deleted) RPC
# module until fully restarted.
if [ -x /etc/init.d/nginx ]; then
    # shellcheck disable=SC2046
    kill -9 $(pgrep nginx) 2>/dev/null
    /etc/init.d/nginx start 2>/dev/null || true
fi

exit 0
