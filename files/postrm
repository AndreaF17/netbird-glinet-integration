#!/bin/sh
# After package files are removed: hard-restart the GL web stack so OpenResty
# workers drop the (now deleted) NetBird RPC module and menu entry, and clean
# up NetBird's transient /tmp state. Live systems only — and only where the
# GL web stack exists.
[ -n "${IPKG_INSTROOT}" ] && exit 0

# Drop NetBird's /tmp state: the binary extracted to RAM (compressed layout),
# the connect/update logs and locks, and the self-update cache + scratch dir.
rm -rf /tmp/netbird-runtime \
       /tmp/netbird-up.log /tmp/netbird-up.lock \
       /tmp/netbird-update.log /tmp/netbird-update.lock \
       /tmp/netbird-update-check.json /tmp/netbird-update

# Hard restart, not reload: OpenResty workers cache the (now deleted) RPC
# module until fully restarted.
if [ -x /etc/init.d/nginx ]; then
    # shellcheck disable=SC2046
    kill -9 $(pgrep nginx) 2>/dev/null
    /etc/init.d/nginx start 2>/dev/null || true
fi

exit 0
