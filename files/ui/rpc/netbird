--[[
    @object-name: netbird
    @object-desc: NetBird client control for the GL.iNet admin panel.

    Loaded by GL's OpenResty RPC dispatcher from /usr/lib/oui-httpd/rpc/.
    Called from the injected frontend via POST /rpc:
      {"jsonrpc":"2.0","method":"call","params":[<Admin-Token>,"netbird","<method>",{...}]}

    Pattern follows gl-tailscale-fix (GPL-3.0, RemoteToHome-io/gl-tailscale-fix).
--]]

local cjson = require "cjson"

local M = {}

local BIN = "/usr/sbin/netbird"           -- wrapper (compressed layout) or the binary (plain)
local INIT = "/etc/init.d/netbird"
local UP_LOG = "/tmp/netbird-up.log"
local UP_LOCK = "/tmp/netbird-up.lock"
local LIBEXEC = "/usr/libexec/netbird"
local BIN_GZ = LIBEXEC .. "/netbird.gz"        -- gzipped binary in the compressed layout
local VERSION_FILE = LIBEXEC .. "/netbird.version"  -- version stamp written by the self-updater
local SSH_ROOT_STATE = "/etc/netbird/.panel_ssh_root"  -- panel-tracked "allow root login" pref
-- Self-update (panel "NetBird update" card). The heavy lifting lives in a
-- shipped shell script so the download/verify/swap logic stays testable and
-- out of the request worker; see files/netbird-self-update.sh.
local SELF_UPDATE = LIBEXEC .. "/netbird-self-update.sh"
local UPD_LOG = "/tmp/netbird-update.log"
local UPD_LOCK = "/tmp/netbird-update.lock"
-- Panel self-update (the "Update now" button on the new-panel banner). Downloads
-- this integration's latest .ipk and opkg-installs it; see panel-self-update.sh.
local PANEL_UPDATE = LIBEXEC .. "/panel-self-update.sh"
local PANEL_LOG = "/tmp/netbird-panel-update.log"
local PANEL_LOCK = "/tmp/netbird-panel-update.lock"
local PANEL_TMP = "/tmp/netbird-panel-update.run.sh"

-- Cached version. Invalidated per-worker when the netbird payload changes.
-- BIN is the wrapper script whose mtime is fixed at install, so the cache is
-- keyed on the files the self-updater actually rewrites (the version stamp,
-- then the gzipped binary), falling back to BIN for the plain layout. Each
-- nginx worker holds its own cache; the mtime check re-reads it without an
-- nginx restart.
local cached_version = nil
local cached_version_mtime = 0

-- Helper: run a command and return stdout
local function exec(cmd)
    local r = ngx.pipe.spawn({"sh", "-c", cmd})
    if r then
        local data = r:stdout_read_all()
        r:wait()
        return data
    end
    return nil
end

-- Helper: run a command and return exit code
local function exec_rc(cmd)
    local r = ngx.pipe.spawn({"sh", "-c", cmd})
    if r then
        r:stdout_read_all()
        local ok, _, code = r:wait()
        if ok then return 0 end
        return code or 1
    end
    return 1
end

-- Helper: file exists
local function file_exists(path)
    local f = io.open(path, "r")
    if f then f:close() return true end
    return false
end

-- Helper: mtime via BusyBox "date -r" (GL routers don't ship stat in PATH)
local function file_mtime(path)
    local r = ngx.pipe.spawn({"date", "-r", path, "+%s"})
    if not r then return 0 end
    local data = r:stdout_read_all()
    r:wait()
    return tonumber((data or ""):match("^(%d+)")) or 0
end

-- A background job (self-update / panel-update) that crashes or is killed leaves
-- its lock behind, which otherwise wedges the UI on "in progress" forever and
-- makes every later attempt return "already in progress". Reap such a lock:
-- stale if the PID it records is no longer alive, or (before the job wrote its
-- PID, or an unreadable lock) if it is older than the TTL. A genuinely running
-- job is left untouched.
local LOCK_TTL = 1200   -- 20 min: comfortably longer than any real update
local function clear_stale_lock(path)
    if not file_exists(path) then return end
    local pid
    local f = io.open(path, "r")
    if f then pid = (f:read("*l") or ""):match("^(%d+)"); f:close() end
    if pid then
        -- kill -0 succeeds while the process is alive (the worker runs as root,
        -- so it can always signal it). Dead PID => the job is gone => stale.
        if exec_rc("kill -0 " .. pid .. " 2>/dev/null") == 0 then return end
        os.remove(path)
        return
    end
    -- No PID recorded yet: fall back to age.
    local mt = file_mtime(path)
    local now = tonumber(os.time()) or 0
    if mt > 0 and now - mt > LOCK_TTL then os.remove(path) end
end

-- Launch `runner` (a shell command string) fully detached from this request
-- worker, so it survives both the RPC returning and any service restart it
-- triggers.
--
-- ngx.pipe puts the shell we spawn into its own process group and SIGKILLs that
-- whole group at request cleanup; a bare `cmd &` background job is still in that
-- group and gets killed before it does anything. `setsid` moves the job into a
-- new session (out of the doomed group); `nohup` (or, last resort, a plain
-- background job with its stdio detached) is the fallback when setsid is absent.
-- The trailing `sleep 1` keeps the ngx-tracked shell alive until setsid has
-- re-parented the job, so cleanup cannot race the detach and kill it first.
--
-- Lock lifecycle (crash-safe): the lock is touched synchronously here so the
-- matching `*_in_progress` flag is true the instant we return; the detached job
-- overwrites it with its own PID and removes it on exit. A job that dies without
-- cleaning up is reaped by clear_stale_lock (dead PID, or older than LOCK_TTL).
local function spawn_detached(lockfile, runner)
    local job = "echo $$ > " .. lockfile .. "; " .. runner .. "; rm -f " .. lockfile
    local full = "touch " .. lockfile .. "; "
        .. "if command -v setsid >/dev/null 2>&1; then "
        .. "setsid sh -c '" .. job .. "' </dev/null >/dev/null 2>&1 & "
        .. "elif command -v nohup >/dev/null 2>&1; then "
        .. "nohup sh -c '" .. job .. "' </dev/null >/dev/null 2>&1 & "
        .. "else sh -c '" .. job .. "' </dev/null >/dev/null 2>&1 & fi; "
        .. "sleep 1"
    local r = ngx.pipe.spawn({"sh", "-c", full})
    if r then r:stdout_read_all(); r:wait() end
end

local function get_version()
    -- Key the cache on what the self-updater rewrites, NOT on BIN (the wrapper
    -- mtime never changes), so a panel-driven binary update is reflected
    -- without an nginx restart.
    local mtime = file_mtime(VERSION_FILE)
    if mtime == 0 then mtime = file_mtime(BIN_GZ) end
    if mtime == 0 then mtime = file_mtime(BIN) end
    if cached_version and mtime > 0 and mtime == cached_version_mtime then
        return cached_version
    end
    -- Prefer the version stamp (fast, no 36 MB extraction); fall back to the
    -- binary itself (timeout-guarded) only when the stamp is missing.
    local ver
    local f = io.open(VERSION_FILE, "r")
    if f then ver = f:read("*l"); f:close() end
    if not ver or ver == "" then
        ver = exec("timeout 10 " .. BIN .. " version 2>/dev/null")
    end
    if ver then ver = ver:gsub("^v", "") end
    cached_version = ver and ver:match("^(%S+)") or "unknown"
    cached_version_mtime = mtime
    return cached_version
end

-- Helper: is the netbird daemon running?
-- Guard with pgrep before spawning the CLI: if the daemon is down, the
-- large Go CLI process would hang until timeout — wasteful on small routers.
-- Matches both layouts: plain /usr/sbin/netbird AND the compressed-binary
-- wrapper (real process is /tmp/netbird-runtime/netbird-<ver> service run).
local function daemon_running()
    return exec_rc("pgrep -f 'netbird[^ ]* service' >/dev/null 2>&1") == 0
end

-- Helper: parsed `netbird status --json`, or nil
-- Generous timeout: with the compressed-binary layout the first CLI call
-- after boot gunzips ~36MB to /tmp before running.
local function netbird_status()
    if not daemon_running() then return nil end
    local data = exec("timeout 10 " .. BIN .. " status --json 2>/dev/null")
    if data and #data > 0 then
        local ok, r = pcall(cjson.decode, data)
        if ok and type(r) == "table" then
            return r
        end
    end
    return nil
end

-- Helper: JSON true/false/null -> true/false/nil (cjson decodes JSON null to
-- cjson.null, which is neither nil nor false).
local function cfg_bool(v)
    if v == true then return true end
    if v == false then return false end
    return nil
end

-- Client-side SSH intent from the persistent client config (netbird >= 0.60
-- persists ServerSSHAllowed and EnableSSHRoot there). This is what the panel
-- toggles control. The SSH server only actually RUNS when the dashboard's
-- per-peer SSH switch is also on (management pushes it), so the live
-- "SSH Server:" state is reported separately (ssh_active in get_status).
local function client_ssh_config()   -- -> allowed|nil, root|nil
    local f = io.open("/etc/netbird/config.json", "r")
    if not f then return nil, nil end
    local data = f:read("*a")
    f:close()
    local ok, cfg = pcall(cjson.decode, data)
    if not ok or type(cfg) ~= "table" then return nil, nil end
    return cfg_bool(cfg.ServerSSHAllowed), cfg_bool(cfg.EnableSSHRoot)
end

-- Helper: "allow root login" state. The client config's EnableSSHRoot is
-- authoritative on netbird >= 0.60; the panel-tracked file (the value the
-- panel last applied) is only the fallback for older clients that don't
-- persist the flag.
local function ssh_root_enabled()
    local _, root = client_ssh_config()
    if root ~= nil then return root end
    local f = io.open(SSH_ROOT_STATE, "r")
    if not f then return false end
    local v = f:read("*l")
    f:close()
    return v == "1"
end

-- Input validation. Values are passed to a shell command line, so the
-- charset is strict: no quotes, spaces, semicolons, backticks, etc.
local function valid_setup_key(s)
    return type(s) == "string" and #s > 0 and #s <= 128
        and s:match("^[%w%-]+$") ~= nil
end

local function valid_url(s)
    return type(s) == "string" and #s > 0 and #s <= 256
        and s:match("^https?://[%w%.%-_]+[%w%.%-_:/]*$") ~= nil
end

--[[
    @method-type: call
    @method-name: get_status
    @method-desc: Live NetBird state for the settings page.

    @out bool   installed       netbird binary present
    @out bool   enabled         service enabled at boot
    @out bool   running         daemon process running
    @out string version         installed netbird version
    @out object status          parsed `netbird status --json` (null when daemon down)
    @out bool   up_in_progress  a `netbird up` launched from this UI is still running
    @out bool   ssh_enabled     client-side "allow SSH server" setting (the toggle)
    @out bool   ?ssh_active     SSH server actually running (needs the dashboard
                                per-peer SSH switch too); absent when unknown
    @out bool   ssh_root_enabled  client-side root-login setting
--]]
function M.get_status()
    local res = {}
    res.installed = file_exists(BIN)
    res.enabled = exec_rc(INIT .. " enabled") == 0
    res.running = daemon_running()
    res.version = get_version()
    clear_stale_lock(UP_LOCK)
    res.up_in_progress = file_exists(UP_LOCK)
    local ssh_allowed = client_ssh_config()
    res.ssh_enabled = ssh_allowed == true
    res.ssh_root_enabled = ssh_root_enabled()

    local status = netbird_status()
    if status then
        res.status = status
        -- Effective server state (netbird >= 0.60 reports it in the JSON).
        -- ssh_enabled true + ssh_active false means the dashboard's per-peer
        -- SSH switch (or the policy) is still missing — surfaced in the UI.
        local srv = status.sshServer
        if type(srv) == "table" and cfg_bool(srv.enabled) ~= nil then
            res.ssh_active = srv.enabled == true
        end
    end

    return res
end

--[[
    @method-type: call
    @method-name: up
    @method-desc: Connect to a NetBird network (runs `netbird up` in background).
                  With a setup key: headless enrollment. Without: SSO flow —
                  the login URL appears in the log (see get_up_log).

    @in string ?setup_key       NetBird setup key (alphanumeric/dashes)
    @in string ?management_url  Self-hosted management URL (default api.netbird.io)
--]]
function M.up(params)
    params = params or {}
    if not file_exists(BIN) then
        return { err_code = -1, err_msg = "netbird binary not found" }
    end
    if not daemon_running() then
        exec_rc(INIT .. " start")
        -- give procd a moment; `netbird up` retries the socket anyway
    end
    clear_stale_lock(UP_LOCK)
    if file_exists(UP_LOCK) then
        return { err_code = -2, err_msg = "A connect attempt is already in progress" }
    end

    local args = ""
    if params.setup_key ~= nil and params.setup_key ~= "" then
        if not valid_setup_key(params.setup_key) then
            return { err_code = -3, err_msg = "Invalid setup key format" }
        end
        args = args .. " --setup-key " .. params.setup_key
    end
    if params.management_url ~= nil and params.management_url ~= "" then
        if not valid_url(params.management_url) then
            return { err_code = -4, err_msg = "Invalid management URL" }
        end
        args = args .. " --management-url " .. params.management_url
    end

    -- Background with lock + log so the UI can poll progress. The charset
    -- validation above makes the interpolation shell-safe. The subshell is
    -- detached from the pipe's stdout (</dev/null >/dev/null 2>&1) so it
    -- survives the parent sh exiting; real output goes to UP_LOG explicitly.
    -- Record the background subshell's PID ($!) in the lock so a job that dies
    -- without clearing it is reaped by clear_stale_lock (dead PID) instead of
    -- wedging the UI until the TTL.
    local cmd = "touch " .. UP_LOCK .. "; "
        .. "(timeout 90 " .. BIN .. " up" .. args .. " > " .. UP_LOG .. " 2>&1; "
        .. "echo \"[exit code: $?]\" >> " .. UP_LOG .. "; "
        .. "rm -f " .. UP_LOCK .. ") </dev/null >/dev/null 2>&1 & echo $! > " .. UP_LOCK
    local r = ngx.pipe.spawn({"sh", "-c", cmd})
    if r then r:stdout_read_all(); r:wait() end

    return { status = "up_started" }
end

--[[
    @method-type: call
    @method-name: set_ssh
    @method-desc: Enable/disable the embedded NetBird SSH server and, optionally,
                  root login (--enable-ssh-root). Toggling either only takes
                  effect after a reconnect — `netbird down` then `netbird up`
                  with the full desired flag set — in BOTH directions: a bare
                  `up` while already connected does not apply the change (NetBird
                  docs / netbird issue #2816). Both flags are passed every time
                  so they don't reset each other. Runs in the background;
                  progress lands in the same log as connect (get_up_log). SSH
                  also needs a "NetBird SSH" access policy in the NetBird
                  dashboard (authorizing root, for root login), otherwise
                  connections are refused even with the server enabled here.

    @in bool  enabled  desired SSH server state
    @in bool ?root     desired root-login state (--enable-ssh-root); when
                       omitted the current panel-tracked value is preserved
--]]
function M.set_ssh(params)
    params = params or {}
    if not file_exists(BIN) then
        return { err_code = -1, err_msg = "netbird binary not found" }
    end
    if not daemon_running() then
        return { err_code = -2, err_msg = "NetBird daemon is not running" }
    end
    clear_stale_lock(UP_LOCK)
    if file_exists(UP_LOCK) then
        return { err_code = -3, err_msg = "Another operation is already in progress" }
    end

    -- Root-login preference. Preserve the current value if the caller didn't
    -- pass one (e.g. when only the SSH-server toggle changed).
    local want_root = params.root
    if want_root == nil then want_root = ssh_root_enabled() end

    -- Toggling the SSH server (or the root flag) only takes effect after a
    -- reconnect, so every change does `netbird down` then `netbird up` with the
    -- full flag set. Passing both flags every time keeps them from resetting
    -- each other; a bare `up` while connected applies nothing (issue #2816).
    local flags
    if params.enabled then
        flags = "--allow-server-ssh "
            .. (want_root and "--enable-ssh-root" or "--enable-ssh-root=false")
    else
        flags = "--allow-server-ssh=false"
    end
    -- Never leave a remote router disconnected: the flagged `up` follows a
    -- `down`, so if it fails (unknown flag on an older client, transient
    -- error) a bare `up` restores the previous connection.
    local cmd = "timeout 15 " .. BIN .. " down; "
        .. "if ! timeout 90 " .. BIN .. " up " .. flags .. "; then "
        .. "echo '[applying SSH flags failed; restoring the connection]'; "
        .. "timeout 90 " .. BIN .. " up; fi"

    -- Record the root preference for the panel toggle's state.
    local rf = io.open(SSH_ROOT_STATE, "w")
    if rf then rf:write(want_root and "1" or "0"); rf:close() end

    -- Wrap the entire command set so all output (including `down`) goes to the
    -- log. Detach the subshell from the pipe's stdout so it survives GC of the
    -- ngx.pipe handle; the real output goes to UP_LOG explicitly.
    local full = "touch " .. UP_LOCK .. "; "
        .. "{ " .. cmd .. " ; } > " .. UP_LOG .. " 2>&1; "
        .. "echo \"[exit code: $?]\" >> " .. UP_LOG .. "; "
        .. "rm -f " .. UP_LOCK
    -- Record the background subshell's PID ($!) in the lock so a dead job is
    -- reaped by clear_stale_lock (dead PID) instead of wedging the UI.
    local outer = "(" .. full .. ") </dev/null >/dev/null 2>&1 & echo $! > " .. UP_LOCK
    local r = ngx.pipe.spawn({"sh", "-c", outer})
    if r then r:stdout_read_all(); r:wait() end

    return { status = "ssh_started" }
end

--[[
    @method-type: call
    @method-name: down
    @method-desc: Disconnect from the NetBird network (`netbird down`).
--]]
function M.down()
    if not daemon_running() then
        return { err_code = -1, err_msg = "NetBird daemon is not running" }
    end
    local r = ngx.pipe.spawn({"sh", "-c", "timeout 15 " .. BIN .. " down >/dev/null 2>&1 &"})
    if r then r:stdout_read_all(); r:wait() end
    return { status = "down_started" }
end

--[[
    @method-type: call
    @method-name: get_up_log
    @method-desc: Tail of the last `netbird up` output (login URL, errors).

    @out string log         last 4KB of the up log
    @out bool   in_progress connect attempt still running
--]]
function M.get_up_log()
    clear_stale_lock(UP_LOCK)
    local res = { log = "", in_progress = file_exists(UP_LOCK) }
    local f = io.open(UP_LOG, "r")
    if f then
        local size = f:seek("end")
        local from = size > 4096 and size - 4096 or 0
        f:seek("set", from)
        res.log = f:read("*a") or ""
        f:close()
    end
    return res
end

--[[
    @method-type: call
    @method-name: service
    @method-desc: Control the netbird init service.

    @in string action  one of: start, stop, restart, enable, disable
--]]
function M.service(params)
    params = params or {}
    local allowed = {
        start = true, stop = true, restart = true,
        enable = true, disable = true,
    }
    local action = params.action
    if type(action) ~= "string" or not allowed[action] then
        return { err_code = -1, err_msg = "Invalid action" }
    end
    -- Synchronous: start/stop/restart can block for a few seconds while procd
    -- settles, which is acceptable here — the UI shows a busy state and
    -- re-polls status once the call returns.
    local rc = exec_rc(INIT .. " " .. action .. " >/dev/null 2>&1")
    if rc ~= 0 and (action == "enable" or action == "disable") then
        -- rc.common enable returns non-zero on some 19.07 builds even on
        -- success; verify with `enabled` before reporting failure.
        local now_enabled = exec_rc(INIT .. " enabled") == 0
        if (action == "enable") == now_enabled then rc = 0 end
    end
    if rc ~= 0 then
        return { err_code = -2, err_msg = "Action '" .. action .. "' failed (rc=" .. rc .. ")" }
    end
    return {}
end

--[[
    @method-type: call
    @method-name: get_log
    @method-desc: Recent netbird daemon log lines from logread.

    @out string log  last ~50 matching lines
--]]
function M.get_log()
    local data = exec("logread 2>/dev/null | grep -i netbird | tail -n 50")
    return { log = data or "" }
end

--[[
    @method-type: call
    @method-name: check_update
    @method-desc: Check netbird's own GitHub Releases for a newer netbird
                  binary and report whether an update is available. No side
                  effects; the result is cached for 30 min by the shipped
                  script so frequent panel loads do not hammer the GitHub API.

    @out bool   ok                check succeeded (network reachable)
    @out string current           installed netbird version (e.g. 0.72.3)
    @out string latest            latest published netbird version
    @out bool   update_available  latest is newer than installed
    @out string html_url          netbird release page
    @out string ?error            present when ok=false
--]]
function M.check_update()
    if not file_exists(SELF_UPDATE) then
        return { ok = false, error = "updater not installed" }
    end
    -- Generous timeout: a cold check makes one small HTTPS call to the API.
    local out = exec("timeout 25 sh " .. SELF_UPDATE .. " check 2>/dev/null")
    if out and #out > 0 then
        local ok, r = pcall(cjson.decode, out)
        if ok and type(r) == "table" then return r end
    end
    return { ok = false, error = "update check failed" }
end

--[[
    @method-type: call
    @method-name: do_update
    @method-desc: Download, checksum-verify and swap in the latest netbird
                  binary (no opkg, no package — just the binary). Runs fully
                  detached (setsid) so it outlives the request worker and
                  survives the netbird daemon restart (and brief tunnel drop)
                  the updater does at the end. Progress is written to the
                  update log; poll get_update_log for it.
--]]
function M.do_update()
    if not file_exists(SELF_UPDATE) then
        return { err_code = -1, err_msg = "updater script not installed" }
    end
    clear_stale_lock(UPD_LOCK)
    if file_exists(UPD_LOCK) then
        return { err_code = -2, err_msg = "An update is already in progress" }
    end
    -- Fully detached (see spawn_detached): outlives this request worker and the
    -- netbird restart the updater does at the end. The updater logs progress to
    -- UPD_LOG; poll get_update_log for it.
    spawn_detached(UPD_LOCK, "sh " .. SELF_UPDATE .. " run")
    return { status = "update_started" }
end

--[[
    @method-type: call
    @method-name: get_update_log
    @method-desc: Tail of the self-update progress log.

    @out string log          last 8KB of the update log
    @out bool   in_progress  an update is still running
--]]
function M.get_update_log()
    clear_stale_lock(UPD_LOCK)
    local res = { log = "", in_progress = file_exists(UPD_LOCK) }
    local f = io.open(UPD_LOG, "r")
    if f then
        local size = f:seek("end")
        local from = size > 8192 and size - 8192 or 0
        f:seek("set", from)
        res.log = f:read("*a") or ""
        f:close()
    end
    return res
end

--[[
    @method-type: call
    @method-name: do_panel_update
    @method-desc: Download THIS integration's latest .ipk from its GitHub
                  Releases into /tmp, verify the sha256, `opkg install` it and
                  remove the .ipk. Runs fully detached (setsid) from a /tmp copy
                  of the updater, so it survives opkg replacing the panel's own
                  files and the nginx restart its postinst triggers. Poll
                  get_panel_update_log; the page must be reloaded afterwards to
                  pick up the new view.
--]]
function M.do_panel_update()
    if not file_exists(PANEL_UPDATE) then
        return { err_code = -1, err_msg = "panel updater not installed" }
    end
    clear_stale_lock(PANEL_LOCK)
    if file_exists(PANEL_LOCK) then
        return { err_code = -2, err_msg = "A panel update is already in progress" }
    end
    -- Stage the updater in /tmp and run THAT copy: opkg overwrites
    -- /usr/libexec/netbird/panel-self-update.sh during the install, which would
    -- otherwise be yanked out from under the running shell. spawn_detached moves
    -- it into its own session so the `kill nginx` in our own postinst cannot
    -- reach the install (and it owns the lock; we only clean up the /tmp copy).
    local runner = "cp " .. PANEL_UPDATE .. " " .. PANEL_TMP
        .. " && sh " .. PANEL_TMP .. " run; rm -f " .. PANEL_TMP
    spawn_detached(PANEL_LOCK, runner)
    return { status = "panel_update_started" }
end

--[[
    @method-type: call
    @method-name: get_panel_update_log
    @method-desc: Tail of the panel self-update progress log.

    @out string log          last 8KB of the panel update log
    @out bool   in_progress  a panel update is still running
--]]
function M.get_panel_update_log()
    clear_stale_lock(PANEL_LOCK)
    local res = { log = "", in_progress = file_exists(PANEL_LOCK) }
    local f = io.open(PANEL_LOG, "r")
    if f then
        local size = f:seek("end")
        local from = size > 8192 and size - 8192 or 0
        f:seek("set", from)
        res.log = f:read("*a") or ""
        f:close()
    end
    return res
end

return M
